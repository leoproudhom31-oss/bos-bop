# Copier ce fichier vers .env puis adapter les valeurs.

# Base de données SQLite (chemin relatif au dossier prisma/)
DATABASE_URL="file:./bosbop.db"

# Secret de session pour l'administration (générer une longue chaîne aléatoire :
#   openssl rand -hex 32
SESSION_SECRET="changez-moi-avec-une-longue-chaine-aleatoire"

# URL publique du site (utilisée pour les liens de partage)
SITE_URL="https://www.bos-bop.fr"

# Identifiants du premier compte administrateur (utilisés par `npm run db:seed`)
ADMIN_EMAIL="admin@bos-bop.fr"
ADMIN_PASSWORD="admin"

# Cookie de session administrateur : marqué "Secure" automatiquement si la
# requête arrive en HTTPS (via l'en-tête x-forwarded-proto d'un reverse
# proxy). Ne définir cette variable QUE si l'auto-détection ne convient pas
# à votre hébergement : "1" force Secure (site en HTTPS sans proxy devant),
# "0" le désactive (dépannage local en HTTP). Laisser vide dans les autres cas.
# COOKIE_SECURE=""

# Paiement en ligne (boutique /livres) : voir le README, section
# « Connecter Stripe », pour la marche à suivre complète. Tant que ces deux
# variables ne sont pas renseignées, la boutique fonctionne normalement sans
# paiement en ligne (règlement organisé manuellement avec chaque client).
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
